# Supabase — required for persistence (stub mode works without these)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth (configure in Supabase Dashboard → Authentication → Providers → Google):
# Set Client ID and Client Secret in the dashboard — not in this repo.
# Redirect URL must include: https://greenlit-six.vercel.app/** and http://localhost:5173/**

# Set to "true" to use deterministic stub instead of Edge Function LLM calls
VITE_LLM_STUB_MODE=true

# Comma-separated allowlist for the /admin/shops UI gate (UX-only — real access
# control is the admin_emails table + is_admin() RLS policies, see 0005 migration)
VITE_ADMIN_EMAILS=yashbolishetti@gmail.com

# Sales contact shown on /for-shops and the shop dashboard Team tab
VITE_SALES_EMAIL=hello@greenlit.co

# Edge Function secrets (set via `supabase secrets set`, not in browser):
# OPENAI_API_KEY=sk-...
# INTERVIEWER_MODEL_ID=gpt-4o-mini
# DIAGNOSTICIAN_MODEL_ID=gpt-4o
# Later fine-tune swap:
# DIAGNOSTICIAN_MODEL_ID=ft:gpt-4o-2024-07:greenlit:diagnostician-v1:abc123
